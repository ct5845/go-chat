{
  "name": "ct-go-chat",
  "image": "mcr.microsoft.com/devcontainers/go:2.1.3-1.26-bookworm",

  "features": {
    "ghcr.io/devcontainers/features/node:1": {
      "version": "24"
    }
  },

  "postCreateCommand": "go install github.com/air-verse/air@latest && npm install",

  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "App", "onAutoForward": "openBrowser" }
  },

  "remoteEnv": {
    "AWS_PROFILE": "${localEnv:AWS_PROFILE}",
    "AWS_REGION": "${localEnv:AWS_REGION}",
    "AWS_ACCESS_KEY_ID": "${localEnv:AWS_ACCESS_KEY_ID}",
    "AWS_SECRET_ACCESS_KEY": "${localEnv:AWS_SECRET_ACCESS_KEY}",
    "AWS_SESSION_TOKEN": "${localEnv:AWS_SESSION_TOKEN}"
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "golang.go"
      ]
    }
  }
}
